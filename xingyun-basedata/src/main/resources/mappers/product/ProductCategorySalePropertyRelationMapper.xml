<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lframework.xingyun.basedata.mappers.ProductCategorySalePropertyRelationMapper">

    <resultMap id="ProductCategorySalePropertyRelationDto" type="com.lframework.xingyun.basedata.entity.ProductCategorySalePropertyRelation">
        <id column="id" property="id"/>
        <result column="property_id" property="propertyId"/>
        <result column="category_id" property="categoryId"/>
    </resultMap>

    <resultMap id="ProductCategory" type="com.lframework.xingyun.basedata.entity.ProductCategory">
        <id column="id" property="id"/>
        <result column="code" property="code"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
    </resultMap>

    <resultMap id="PropertyCategoryCountDto" type="com.lframework.xingyun.basedata.dto.product.category.PropertyCategoryCountDto">
        <id column="property_id" property="propertyId"/>
        <result column="category_count" property="categoryCount"/>
    </resultMap>

    <resultMap id="QueryProductCategorySalePropertyRelationDto" type="com.lframework.xingyun.basedata.dto.product.category.saleproperty.ProductCategorySalePropertyRelationDto">
        <id column="id" property="id"/>
        <result column="property_id" property="propertyId"/>
        <result column="category_id" property="categoryId"/>
        <result column="code" property="code"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
    </resultMap>

    <sql id="ProductCategorySalePropertyRelationDto_sql">
        SELECT cp.id,
            cp.property_id,
            cp.category_id
        FROM base_data_product_category_sale_property_relation AS cp
    </sql>

    <select id="getByPropertyId" resultMap="ProductCategorySalePropertyRelationDto">
        <include refid="ProductCategorySalePropertyRelationDto_sql"/>
        WHERE cp.property_id = #{propertyId}
    </select>

    <select id="getCategoriesByPropertyId" resultMap="ProductCategory">
        SELECT
            c.id,
            c.code,
            c.name,
            c.description
        FROM base_data_product_category_sale_property_relation AS cp
        INNER JOIN base_data_product_category AS c ON c.id = cp.category_id AND c.available = TRUE
        WHERE cp.property_id = #{propertyId}
        ORDER BY c.code
    </select>

    <select id="countCategoriesByPropertyIds" resultMap="PropertyCategoryCountDto">
        SELECT
            cp.property_id,
            COUNT(1) AS category_count
        FROM base_data_product_category_sale_property_relation AS cp
        INNER JOIN base_data_product_category AS c ON c.id = cp.category_id AND c.available = TRUE
        WHERE cp.property_id IN
        <foreach collection="propertyIds" item="propertyId" open="(" close=")" separator=",">
            #{propertyId}
        </foreach>
        GROUP BY cp.property_id
    </select>

    <select id="getByCategoryId" resultMap="QueryProductCategorySalePropertyRelationDto">
        SELECT
            cp.id,
            cp.property_id,
            cp.category_id,
            p.code,
            p.name,
            p.description
        FROM base_data_product_category_sale_property_relation AS cp
        INNER JOIN base_data_product_sale_property_definition AS p ON p.id = cp.property_id AND p.available = TRUE
        WHERE cp.category_id = #{categoryId}
        ORDER BY p.code
    </select>
</mapper>
