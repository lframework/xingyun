<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lframework.xingyun.basedata.mappers.ProductSalePropertyMapper">

    <resultMap id="ProductSaleProperty" type="com.lframework.xingyun.basedata.entity.ProductSaleProperty">
        <id column="id" property="id"/>
        <result column="code" property="code"/>
        <result column="name" property="name"/>
        <result column="available" property="available"/>
        <result column="description" property="description"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <resultMap id="ProductSalePropertyModelorDto"
               type="com.lframework.xingyun.basedata.dto.product.saleproperty.ProductSalePropertyModelorDto">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <collection property="items"
                    ofType="com.lframework.xingyun.basedata.dto.product.saleproperty.ProductSalePropertyModelorDto$ProductSalePropertyItemModelorDto"
                    javaType="java.util.ArrayList">
            <id column="item_id" property="id"/>
            <result column="item_name" property="name"/>
        </collection>
    </resultMap>

    <sql id="ProductSalePropertyDto_sql">
        SELECT
            p.id,
            p.code,
            p.name,
            p.available,
            p.description,
            p.create_by,
            p.create_time,
            p.update_by,
            p.update_time
        FROM base_data_product_sale_property AS p
    </sql>

    <select id="query" resultMap="ProductSaleProperty">
        <include refid="ProductSalePropertyDto_sql"/>
        <where>
            <if test="vo != null">
                <if test="vo.code != null and vo.code != ''">
                    AND p.code = #{vo.code}
                </if>
                <if test="vo.name != null and vo.name != ''">
                    AND p.name LIKE CONCAT('%', #{vo.name}, '%')
                </if>
            </if>
            AND p.available = TRUE
        </where>
        ORDER BY p.code
    </select>

    <select id="getModelor" resultMap="ProductSalePropertyModelorDto">
        SELECT
            p.id,
            p.name,
            i.id AS item_id,
            i.name AS item_name
        FROM base_data_product_sale_property AS p
        INNER JOIN base_data_product_sale_property_item AS i ON i.property_id = p.id AND i.available = TRUE
        WHERE p.available = TRUE
        ORDER BY p.code, i.code
    </select>
</mapper>
